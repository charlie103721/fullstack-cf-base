{
	"name": "my-hono-app",
	"type": "module",
	"scripts": {
		"dev": "concurrently --kill-others-on-fail -n client,server -c blue,green \"bun run dev:client\" \"bun run dev:server\"",
		"dev:client": "portless run vite",
		"dev:server": "portless api.$(node -p \"require('./package.json').name\") tsx watch --env-file=.env --clear-screen=false --include='server/**/*.ts' --include='server/**/*.tsx' server/dev.ts",
		"build": "vite build",
		"preview": "bun run build && wrangler dev",
		"deploy": "bun run build && bun run db:migrate:prod && wrangler deploy",
		"db:migrate:prod": "DOTENV_CONFIG_PATH=.env.prod drizzle-kit migrate",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"test": "vitest",
		"test:run": "vitest run",
		"test:server": "vitest --project server",
		"test:client": "vitest --project client",
		"lint": "eslint .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"secrets:push": "bun scripts/push-secrets.ts"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-query": "^5.90.21",
		"better-auth": "^1.4.18",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.9",
		"lucide-react": "^0.564.0",
		"pg": "^8.18.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-icons": "^5.5.0",
		"react-router": "^7.13.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.2.3",
		"@types/pg": "^8.18.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/browser": "^4.0.18",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.31.9",
		"eslint": "^10.0.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.0",
		"globals": "^17.3.0",
		"jsdom": "^28.0.0",
		"shadcn": "^3.8.4",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript-eslint": "^8.55.0",
		"vite": "^6.3.5",
		"vitest": "^4.0.18",
		"wrangler": "^4.65.0"
	}
}
